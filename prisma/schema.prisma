generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== USERS & AUTH =====================

enum UserRole {
  USER
  TEACHER
  ADMIN
}

model User {
  id                String   @id @default(cuid())
  name              String?
  email             String?  @unique
  emailVerified     DateTime?
  image             String?
  telegramId        String?  @unique
  telegramUsername  String?
  googleId          String?  @unique
  role              UserRole @default(USER)
  lang              String   @default("uz")
  referralCode      String?  @unique
  referredBy        String?
  lastActiveAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  teacher           Teacher?
  subscriptions     Subscription[]
  permissions       UserPermission[]
  testResults       TestResult[]
  payments          Payment[]
  confirmedPayments Payment[]    @relation("ConfirmedBy")
  referralsMade     Referral[]   @relation("ReferralsMade")
  referralsReceived Referral[]   @relation("ReferralsReceived")
  notifications     Notification[]
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referredUserId String
  createdAt      DateTime @default(now())

  referrer     User @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReferralsReceived", fields: [referredUserId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===================== TEACHERS =====================

model Teacher {
  id         String   @id @default(cuid())
  userId     String   @unique
  subjectId  String
  bio        String?
  verified   Boolean  @default(false)
  rating     Float    @default(0)
  createdAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])
  tests   Test[]
}

// ===================== SUBJECTS & CATEGORIES =====================

enum TestType {
  DTM
  SCHOOL
  ATTESTATION
  SAT
  GRE
  CERTIFICATE
  PRESIDENT_SCHOOL
}

enum PlanType {
  FREE
  PREMIUM
  TEACHER_PLAN
}

model TestCategory {
  id           String   @id @default(cuid())
  nameUz       String
  nameRu       String
  nameEn       String
  type         TestType
  requiredPlan PlanType @default(PREMIUM)
  icon         String?
  description  String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  subjects Subject[]
  permissions UserPermission[]
}

model Subject {
  id         String   @id @default(cuid())
  nameUz     String
  nameRu     String
  nameEn     String
  icon       String?
  categoryId String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  category TestCategory @relation(fields: [categoryId], references: [id])
  teachers Teacher[]
  tests    Test[]
}

// ===================== TESTS & QUESTIONS =====================

enum QuestionType {
  MULTIPLE_CHOICE
  OPEN_ENDED
}

model Test {
  id              String       @id @default(cuid())
  titleUz         String
  titleRu         String?
  titleEn         String?
  categoryId      String
  subjectId       String
  teacherId       String?
  price           Int          @default(0)
  isFree          Boolean      @default(false)
  accessType      String       @default("free") // free, premium, teacher, premium_teacher, paid
  duration        Int          // in minutes
  questionCount   Int
  format          QuestionType @default(MULTIPLE_CHOICE)
  difficulty      Int          @default(1) // 1-5
  coverImage      String?      // Cover image URL
  videoSolution   String?      // URL
  writtenSolution String?      // LaTeX text
  isPublished     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  subject   Subject       @relation(fields: [subjectId], references: [id])
  teacher   Teacher?      @relation(fields: [teacherId], references: [id])
  questions Question[]
  results   TestResult[]
}

model Question {
  id                 String       @id @default(cuid())
  testId             String
  text               String       // LaTeX supported
  images             String[]     // Array of image URLs for question
  options            Json         // [{label, text, image}] — A,B,C,D,E (E optional)
  correctAnswer      String       // "A", "B", "C", "D", "E" or open text
  type               QuestionType @default(MULTIPLE_CHOICE)
  explanation        String?      // LaTeX written solution
  explanationImages  String[]     // Images in explanation
  videoUrl           String?      // Video solution URL
  points             Int          @default(1)
  order              Int          @default(0)
  createdAt          DateTime     @default(now())

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
}

// ===================== RESULTS =====================

model TestResult {
  id          String   @id @default(cuid())
  userId      String
  testId      String
  score       Int
  maxScore    Int
  percentage  Float
  answers     Json     // [{questionId, answer, isCorrect, timeSpent}]
  timeSpent   Int      // in seconds
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  test Test @relation(fields: [testId], references: [id])
}

// ===================== SUBSCRIPTIONS & PAYMENTS =====================

enum SubscriptionPlan {
  PREMIUM
  TEACHER_PLAN
}

enum SubscriptionDuration {
  ONE_MONTH
  SIX_MONTHS
  ONE_YEAR
}

model Subscription {
  id        String               @id @default(cuid())
  userId    String
  plan      SubscriptionPlan
  duration  SubscriptionDuration
  startDate DateTime             @default(now())
  endDate   DateTime
  isActive  Boolean              @default(true)
  paymentId String?              @unique
  createdAt DateTime             @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id])
}

model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  grantedBy  String?  // Admin who granted
  expiresAt  DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category TestCategory @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId])
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model Payment {
  id               String               @id @default(cuid())
  userId           String
  plan             SubscriptionPlan
  duration         SubscriptionDuration
  amount           Int
  status           PaymentStatus        @default(PENDING)
  receiptPhoto     String?              // Uploaded receipt image URL
  telegramMsgId    String?              // Telegram message ID
  confirmedById    String?              // Admin who confirmed
  confirmedAt      DateTime?
  selectedSubjects String[]             // For TEACHER_PLAN — selected subject IDs
  createdAt        DateTime             @default(now())

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  confirmedBy User?         @relation("ConfirmedBy", fields: [confirmedById], references: [id])
  subscription Subscription?
}

// ===================== NOTIFICATIONS =====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===================== SYSTEM SETTINGS =====================

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
